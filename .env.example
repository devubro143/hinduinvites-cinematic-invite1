# Google Apps Script Web App URL for Google Sheets RSVP Destination
VITE_APPS_SCRIPT_URL=https://script.google.com/macros/s/...

# Optional: Telegram Integration for real-time guest RSVP notifications
VITE_TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
VITE_TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# Optional: Google Spreadsheet ID (For developer reference)
VITE_GOOGLE_SPREADSHEET_ID=YOUR_SPREADSHEET_ID
